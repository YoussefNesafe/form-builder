# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# generated at build/dev time by scripts/zip-form-builder.mjs
/public/form-builder.zip

# generated at build/dev time by scripts/build-registry.mjs + `shadcn build`
# (Phase 2 registry — see docs/adr/0003-packaging-split-distribution.md;
# documentation/metadata artifact only — the CLI at cli/ does a direct copy
# + import-rewrite for the file tree and a direct globals.css write for the
# theme, neither goes through shadcn)
/registry/registry.json
/public/r/

# built output of the form-builder/ package (tsup) — publishable artifact,
# not source
/form-builder/dist

# built output of cli/scripts/vendor.mjs — makes the cli/ package
# self-sufficient for `npm publish`; regenerated by `prepack`, never
# hand-edited (see cli/package.json)
/cli/vendor/

# production
/build

# misc
.DS_Store
*.pem

# browser automation artifacts
.playwright-mcp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
